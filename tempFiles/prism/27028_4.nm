formula northInt = north?1:0;

formula southInt = south?1:0;

formula eastInt = east?1:0;

formula westInt = west?1:0;

formula numDirNorth = westInt + northInt + eastInt;

formula numDirSouth = southInt + eastInt + westInt;

formula numDirEast = northInt + southInt + eastInt;

formula numDirWest = northInt + southInt + westInt;


module robot

x : [0..9] init 3;
y : [0..9] init 2;

[North] ((initAction = 0 | initAction = 3 | initStep = false) & north & !win & !loss & !end) -> (10 * northInt)/(numDirNorth+9): (x'=x-1) & (initStep' = false) + (1 * eastInt)/(numDirNorth+9): (y'=y+1) & (initStep' = false) + (1 * westInt)/(numDirNorth+9): (y'=y-1) & (initStep' = false);
[South] ((initAction = 0 | initAction = 4 | initStep = false) & south  & !win & !loss & !end) -> (10 * southInt)/(numDirSouth+9): (x'=x+1) & (initStep' = false) + (1 * eastInt)/(numDirSouth+9): (y'=y+1) & (initStep' = false) + (1 * westInt)/(numDirSouth+9): (y'=y-1) & (initStep' = false);
[East] ((initAction = 0 | initAction = 1 | initStep = false) & east  & !win & !loss & !end) -> (1 * northInt)/(numDirEast+9): (x'=x-1) & (initStep' = false) + (1 * southInt)/(numDirEast+9): (x'=x+1) & (initStep' = false) + (10 * eastInt)/(numDirEast+9): (y'=y+1) & (initStep' = false);
[West] ((initAction = 0 | initAction = 2 | initStep = false) & west & !win & !loss & !end) -> (1 * northInt)/(numDirWest+9): (x'=x-1) & (initStep' = false) + (1 * southInt)/(numDirWest+9): (x'=x+1) & (initStep' = false) + (10 * westInt)/(numDirWest+9): (y'=y-1) & (initStep' = false);
[] (win | loss) -> 1 : (end' = true);

endmodule

rewards
[East] true : -1;
[West] true: -1;
[North] true: -1;
[South] true: -1;
(win & !end) : 100;
(loss & !end) : -100;
endrewards

label "win" = win;
label "loss" = loss;
